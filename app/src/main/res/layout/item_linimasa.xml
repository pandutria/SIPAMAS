<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:layout_marginBottom="-15dp"
    android:layout_marginHorizontal="15dp">

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_horizontal"
        android:layout_marginTop="12dp"
        android:orientation="vertical">

        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/ic_circle_linimasa"/>

        <View
            android:id="@+id/line"
            android:layout_width="2dp"
            android:layout_height="35dp"
            android:layerType="software"
            android:background="@drawable/bg_dash_linimasa"
            />

    </LinearLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="8dp"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status Diperbarui Menjadi Diproses"
            android:fontFamily="@font/poppins_semibold"
            android:textColor="@color/textPrimary"
            android:textSize="15sp"/>

       <LinearLayout
           android:layout_width="wrap_content"
           android:layout_height="wrap_content"
           android:gravity="center_vertical"
           android:orientation="horizontal">

           <TextView
               android:id="@+id/tvUpdatedBy"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="Diperbarui oleh Admin"
               android:fontFamily="@font/poppins_medium"
               android:textColor="@color/textSecondary"
               android:textSize="11sp"/>
           
           <ImageView
               android:layout_width="5dp"
               android:layout_height="5dp"
               android:layout_marginHorizontal="5dp"
               android:src="@drawable/ic_circle"/>

           <TextView
               android:id="@+id/tvDate"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               android:text="20 December, 2025"
               android:fontFamily="@font/poppins_medium"
               android:textColor="@color/textSecondary"
               android:textSize="11sp"/>


       </LinearLayout>

    </LinearLayout>

</LinearLayout>